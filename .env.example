# App
APP__NAME=PiggyBank Backend
APP__VERSION=0.1.0
APP__ENV=local
APP__DEBUG=false
APP__HOST=0.0.0.0
APP__PORT=8000

# Database
DATABASE__URL=postgresql+psycopg://postgres:postgres@localhost:5432/piggybank
DATABASE__ECHO=false

# Twilio
TWILIO__ACCOUNT_SID=your_twilio_account_sid
TWILIO__AUTH_TOKEN=your_twilio_auth_token
TWILIO__PHONE_NUMBER=+15555555555
TWILIO__VALIDATE_SIGNATURE=true

# Gemini
GEMINI__API_KEY=your_gemini_api_key
GEMINI__MODEL=gemini-2.5-flash

# Plaid
PLAID__CLIENT_ID=your_plaid_client_id
PLAID__SECRET=your_plaid_secret
PLAID__ENV=sandbox
PLAID__WEBHOOK_URL=
PLAID__TRANSACTIONS_DAYS_REQUESTED=180

# Scheduler
SCHEDULER__ENABLED=true
SCHEDULER__INTERVAL_SECONDS=60

# Prediction
PREDICTION__NUDGE_PROBABILITY_THRESHOLD=0.65
PREDICTION__NUDGE_COOLDOWN_MINUTES=120
